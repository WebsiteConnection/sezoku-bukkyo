---
interface Props {
  author: string;
  socialLinks: { text: string; href: string }[];
}

const { author, socialLinks } = Astro.props;
---

<footer class="mt-20 border-t border-neutral-800 pt-10 pb-20">
  <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
    <div class="flex flex-col gap-2">
      <p class="text-sm text-neutral-400">
        &copy; {new Date().getFullYear()} {author}. All rights reserved.
      </p>
      <p class="text-xs text-neutral-500">
        The Secular Buddhism Hub — Documenting the transition to immanence.
      </p>
    </div>

    <div class="flex gap-4">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-neutral-400 transition-colors hover:text-white"
            target="_blank"
            rel="noopener noreferrer"
          >
            {link.text}
          </a>
        ))
      }
    </div>
  </div>
</footer>
