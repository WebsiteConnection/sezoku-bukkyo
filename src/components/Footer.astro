---
interface Props {
  socialLinks: { text: string; href: string }[];
}

const { socialLinks } = Astro.props;
---

<footer class="pb-8">
  <div class="flex flex-col gap-6">
    <div class="flex flex-col gap-1">
      <span class="text-sm font-normal text-neutral-200 text-shadow-sm">
        John Tate
      </span>
      <a 
        href="mailto:SecularLotus@gmail.com" 
        class="text-sm font-normal text-neutral-400 transition-colors duration-200 hover:text-primary text-shadow-sm w-fit"
      >
        SecularLotus@gmail.com
      </a>
    </div>

    <div class="flex gap-4">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-neutral-400 transition-colors hover:text-white"
            target="_blank"
            rel="noopener noreferrer"
          >
            {link.text}
          </a>
        ))
      }
    </div>
  </div>
</footer>
