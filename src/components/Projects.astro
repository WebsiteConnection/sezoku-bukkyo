---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { ProjectsProps } from "@types";

interface Props {
  sites: ProjectsProps[];
}

const { sites } = Astro.props;
---

<Section text="ハブ" href="sites">
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    {
      sites.map(({ name, summary, image, links }, index) => {
        const hasSummary = summary && summary.trim() !== "";
        
        return (
          <div 
            class="group relative flex flex-col rounded-3xl border border-white/10 bg-[#1a1a1a] p-6 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary/20 animate-slide-in"
            style={`animation-delay: ${index * 100}ms;`}
          >
            <div>
              <div class="mb-5 flex items-center justify-center">
                <div class="h-16 w-full max-w-[140px] overflow-hidden rounded-xl bg-[#1a1a1a] p-1 flex items-center justify-center">
                  <Image
                    src={image}
                    alt={name}
                    width={140}
                    height={64}
                    class="h-full w-full object-contain mx-auto"
                  />
                </div>
              </div>
              
              <h3 
                class="mb-2 text-xl font-medium text-white group-hover:text-primary transition-colors"
                style="font-family: 'Yu Mincho', 'YuMincho', 'Hiragino Mincho ProN', 'MS PMincho', serif;"
              >
                {name}
              </h3>

              {hasSummary && (
                <p 
                  class="mb-6 text-sm leading-relaxed text-neutral-300 text-justify"
                  style="word-break: break-all;"
                >
                  {summary}
                </p>
              )}
            </div>

            <div class={hasSummary ? "mt-auto flex flex-wrap gap-x-4 gap-y-2 border-t border-white/10 pt-4" : "mt-2 flex flex-wrap gap-x-3 gap-y-2.5 pt-2"}>
            {links && links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-0.5 text-[11px] font-medium text-neutral-300 transition-colors duration-200 hover:text-primary"
              >
                {link.text}
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </a>
            ))}
          </div>
          </div>
        );
      })
    }
  </div>
</Section>

<style>
  .animate-slide-in {
    opacity: 0;
    transform: translateY(20px);
    animation: slideIn 0.6s ease-out forwards;
  }

  @keyframes slideIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
