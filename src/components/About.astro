---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { AboutProps, HeroProps } from "@types";

type Props = AboutProps & Pick<HeroProps, "name">;

const { description, image, name } = Astro.props;
---

<Section text="About" href="about">
  <div class="flex flex-col items-center gap-12 md:flex-row md:gap-8">
    <p class="w-auto text-base text-neutral md:pr-5">{description}</p>
    
    <div class="flex h-auto w-64 shrink-0 rotate-[5deg] flex-col items-center bg-white p-4 pb-6 shadow-xl md:rotate-[7deg]">
      <Image
        class="aspect-square object-cover"
        src={image}
        width="260"
        height="260"
        alt={name}
      />
      
      <p class="mt-4 font-serif text-[11px] italic leading-tight text-neutral-800 text-center px-1">
        A spoke for each of the 24 virtues.
      </p>
    </div>
  </div>
</Section>
