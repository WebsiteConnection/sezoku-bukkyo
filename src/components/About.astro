---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { AboutProps, HeroProps } from "@types";

type Props = AboutProps & Pick<HeroProps, "name">;

const { description, image, name } = Astro.props;
---

<Section text="当サイトについて" href="about">
  <div class="flex flex-col items-center gap-8 md:flex-row">
    
    <div class="w-full rounded-3xl border border-white/10 bg-[#1a1a1a] p-6 shadow-xl md:p-8">
      <p class="text-base leading-relaxed text-neutral-200 text-justify whitespace-pre-line m-0">
        {description}
      </p>
    </div>
    
    <div class="flex h-auto w-64 shrink-0 rotate-[5deg] flex-col items-center bg-white p-4 pb-6 shadow-2xl md:rotate-[7deg]">
      <Image
        class="aspect-square object-cover"
        src={image}
        width={260}
        height={260}
        alt={name}
      />
      <p class="mt-4 font-serif text-[11px] italic leading-tight text-neutral-800 text-center px-1">
        24の徳目を表すスポーク
      </p>
    </div>
  </div>
</Section>
