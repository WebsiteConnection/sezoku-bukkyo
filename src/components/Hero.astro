---
import type { HeroProps } from "@types";
type Props = HeroProps;

const { name, specialty, summary } = Astro.props;
---

<section class="pt-8 pb-16 md:pt-12 md:pb-20" id="hero">
  <!-- Name: Large commanding presence, protected from breaking apart -->
  <h1
    class="mb-3 text-7xl font-bold tracking-tight text-white sm:text-8xl md:mb-2 md:text-9xl break-keep whitespace-nowrap"
    style="font-family: 'Yu Mincho', 'YuMincho', 'Hiragino Mincho ProN', 'MS PMincho', serif;"
  >
    {name}
  </h1>

  <!-- Tagline: Carefully scaled mobile font sizes to prevent automatic character dropping -->
  <p
    class="mb-9 text-2xl sm:text-4xl md:text-6xl font-bold tracking-tight text-primary leading-tight sm:leading-none md:leading-[1.1]"
    style="font-family: 'Yu Mincho', 'YuMincho', 'Hiragino Mincho ProN', 'MS PMincho', serif; break-inside: avoid;"
  >
    世俗仏教運動のための<br />グローバル・ポータル
  </p>

<!-- Summary: Precision Japanese typographic layout protection -->
  <p 
    class="mb-6 text-lg font-normal text-neutral-200 md:text-xl max-w-none text-shadow-sm leading-relaxed"
    style="word-break: keep-all; overflow-wrap: anywhere; line-break: strict;"
  >
    {summary}
  </p>
</section>

<style>
  /* Invisible drop-shadow that shields text from bright backgrounds */
  .text-shadow-sm {
    text-shadow: 
      0 2px 4px rgba(0, 0, 0, 0.9), 
      0 4px 12px rgba(0, 0, 0, 0.8);
  }
</style>
