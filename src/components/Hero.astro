---
import type { HeroProps } from "@types";
type Props = HeroProps;

const { name, specialty, summary } = Astro.props;
---

<section class="pt-8 pb-16 md:pt-12 md:pb-20" id="hero">
  <!-- Name: Pushed up one size step. Enforced whitespace-nowrap so characters never break apart -->
  <h1
    class="mb-3 text-7xl font-bold tracking-tight text-white sm:text-8xl md:mb-2 md:text-9xl break-keep whitespace-nowrap"
    style="font-family: 'Yu Mincho', 'YuMincho', 'Hiragino Mincho ProN', 'MS PMincho', serif;"
  >
    {name}
  </h1>

  <!-- Tagline: Uses leading-none to bring lines tightly together, with an explicit manual break point -->
  <p
    class="mb-9 text-3xl font-bold tracking-tight text-primary sm:text-3xl md:text-4xl leading-none md:leading-tight"
    style="font-family: 'Yu Mincho', 'YuMincho', 'Hiragino Mincho ProN', 'MS PMincho', serif;"
  >
    世俗仏教運動のための<br class="md:hidden" />グローバル・ポータル
  </p>

  <!-- Summary: Boosted text size. Keep-all forces entire words/phrases to flow naturally together without clipping -->
  <p 
    class="mb-6 text-lg font-normal text-neutral-200 md:text-xl max-w-3xl text-shadow-sm"
    style="word-break: keep-all; overflow-wrap: break-word;"
  >
    {summary}
  </p>
</section>

<style>
  /* Invisible drop-shadow that shields text from bright backgrounds */
  .text-shadow-sm {
    text-shadow: 
      0 2px 4px rgba(0, 0, 0, 0.9), 
      0 4px 12px rgba(0, 0, 0, 0.8);
  }
</style>
