---
import type { HeroProps } from "@types";
type Props = HeroProps;

const { name, specialty, summary } = Astro.props;
---

<section class="pt-8 pb-16 md:pt-12 md:pb-20" id="hero">
  <h1
    class="mb-3 text-6xl font-bold tracking-tight text-white sm:text-7xl md:mb-2 md:text-8xl"
    style="font-family: 'Yu Mincho', 'YuMincho', 'Hiragino Mincho ProN', 'MS PMincho', serif;"
  >
    {name}
  </h1>
  <p
    class="mb-9 text-2xl leading-relaxed font-bold tracking-tight text-primary sm:text-3xl md:text-4xl"
    style="font-family: 'Yu Mincho', 'YuMincho', 'Hiragino Mincho ProN', 'MS PMincho', serif;"
  >
    {specialty}
  </p>
  <p 
    class="mb-6 text-base font-normal text-neutral-200 md:text-lg max-w-3xl text-shadow-sm"
    style="word-break: break-all;"
  >
    {summary}
  </p>
</section>

<style>
  /* Invisible drop-shadow that shields text from bright backgrounds */
  .text-shadow-sm {
    text-shadow: 
      0 2px 4px rgba(0, 0, 0, 0.9), 
      0 4px 12px rgba(0, 0, 0, 0.8);
  }
</style>
